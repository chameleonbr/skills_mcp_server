API_KEY=your_api_key

# ── Skills Storage ──────────────────────────────────────────────────────────
# Choose the storage backend: "local" (default) or "s3"
SKILLS_STORAGE=local
SKILLS_DIR=skills

# ── S3 Settings (required when SKILLS_STORAGE=s3) ───────────────────────────
S3_BUCKET=
S3_PREFIX=skills/
S3_CACHE_DIR=.s3cache

# AWS credentials (standard boto3 chain also works: ~/.aws/credentials, IAM role…)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Optional: custom endpoint for MinIO or LocalStack
# AWS_ENDPOINT_URL=http://localhost:9000